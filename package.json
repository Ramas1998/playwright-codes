{
  "name": "playwright-flaky-guardian",
  "version": "0.1.0",
  "description": "Flaky test analyzer and dashboard for Playwright Test.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "flaky-guardian": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "dev:dashboard": "ts-node src/dashboard/server.ts",
